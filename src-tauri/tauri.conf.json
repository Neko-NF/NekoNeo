{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NekoNeo",
  "version": "2.0.0-alpha",
  "identifier": "com.nekonf.nekoneo",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NekoNeo",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
