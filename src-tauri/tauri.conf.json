{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NekoNeo",
  "version": "1.0.0",
  "identifier": "com.nekonf.nekoneo",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NekoNeo",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRGOUUxREM4RDU0MTc3QUUKUldTdWQwSFZ5QjJlVHdmcG9IMW1VdVRhV3grRy9yUEZQZU9ISWxRSTdGV3NieEZFKzRaYUtCdUkK",
      "endpoints": [
        "https://github.com/Neko-NF/NekoNeo/releases/latest/download/latest.json"
      ]
    }
  }
}
